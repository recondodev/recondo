{
  "name": "recondo-api",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "Recondo GraphQL API (Sprint 4)",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node-pg-migrate --migration-file-language sql --migrations-dir migrations",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@as-integrations/fastify": "^3.1.0",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@fastify/cors": "^11.2.0",
    "@recondo/data": "workspace:*",
    "dataloader": "^2.2.3",
    "fastify": "^5.8.2",
    "graphql": "^16.9.0",
    "pg": "^8.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-resolvers": "^5.1.7",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "node-pg-migrate": "^7.0.0",
    "testcontainers": "^11.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
